<%= link_to url,
  class: css_class,
  aria: { label: label },
  data: { turbo_frame: "modal" } do %>
  <svg class="fab__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="<%= icon_path %>"/>
  </svg>
<% end %>
