<% content_for :title, @debt.name %>

<div class="page-container page-container--narrow">
  <header class="page-header">
    <p class="page-header__subtitle"><%= t(".subtitle.#{ @debt.direction }") %></p>
  </header>

  <div class="page-content"
       data-controller="infinite-scroll"
       data-infinite-scroll-url-value="<%= debt_path(id: @debt.id) %>"
       data-infinite-scroll-page-value="<%= @has_more ? @page + 1 : 0 %>">
    <%= render Ui::CommitmentCardComponent.new(
      title: @debt.name,
      current_value: @debt.total_reimbursed,
      target_value: @debt.total_lent,
      currency: current_space.currency,
      accent: "warning",
      progress_label: t('debts.index.repaid_label'),
      complete_label: t('debts.index.settled_label'),
      remaining_label: t('debts.index.remaining_label')
    ) %>

    <div class="commitment-actions">
      <div class="action-buttons">
        <%= render Ui::ButtonComponent.new(
          text: t('.add_transaction'),
          url: new_transaction_path(debt_id: @debt.id, kind: @debt.direction == 'lent' ? 'debt_in' : 'debt_out'),
          variant: :primary,
          size: :lg,
          full_width: true,
          data: { turbo_frame: "modal" }
        ) %>

        <%= render Ui::ButtonComponent.new(
          text: t('.edit_debt'),
          url: edit_debt_path(id: @debt.id),
          variant: :"outline-secondary",
          size: :lg,
          full_width: true,
          data: { turbo_frame: "modal" }
        ) %>
      </div>
    </div>

    <% if @debt.note.present? %>
      <div class="commitment-note">
        <h3 class="commitment-section-title"><%= t('.note_title') %></h3>
        <p><%= @debt.note %></p>
      </div>
    <% end %>

    <div class="commitment-transactions">
      <h2 class="commitment-section-title"><%= t('.recent_transactions') %></h2>
      <% if @transactions.any? %>
        <div id="transactions-container" class="transactions-timeline">
          <%= render partial: "shared/transactions_list", locals: { grouped_transactions: @grouped_transactions } %>
        </div>

        <div id="loading-spinner"
             data-infinite-scroll-target="spinner"
             class="dashboard__spinner hidden">
          <div class="dashboard__spinner-icon"></div>
          <p class="dashboard__spinner-text"><%= t('home.show.loading') %></p>
        </div>

        <% if @has_more %>
          <div id="infinite-scroll-trigger"
               data-infinite-scroll-target="trigger"
               class="dashboard__load-trigger"></div>
        <% end %>
      <% else %>
        <div class="empty-state">
          <p><%= t('.no_transactions') %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%= render Ui::FabComponent.new(url: new_debt_path(direction: @debt.direction), label: t('.add_debt')) %>
