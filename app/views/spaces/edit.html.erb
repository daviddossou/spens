<% content_for :title, t('.title') %>

<%= turbo_frame_tag "modal" do %>
  <div class="page-container page-container--narrow">
    <header class="page-header">
      <p class="page-header__subtitle"><%= t('.subtitle') %></p>
    </header>

    <div class="page-content">
      <%= form_with model: @space,
                    url: space_path(id: @space.id),
                    method: :patch,
                    class: "space-form" do |f| %>
        <%= render 'form', form: f %>

        <div class="space-form__actions">
          <%= render Ui::ButtonComponent.new(
            text: t('.submit'),
            type: :submit,
            variant: :primary,
            size: :lg,
            full_width: true
          ) %>
          <% if @can_delete %>
            <div class="space-form__danger-zone">
              <%= render Ui::ButtonComponent.new(
                text: t('.delete_space'),
                url: space_path(id: @space.id),
                method: :delete,
                variant: :danger,
                size: :lg,
                full_width: true,
                data: { turbo_confirm: t('.confirm_delete', name: @space.name) }
              ) %>
            </div>
          <% end %>
        </div>
      <% end %>

    </div>
  </div>
<% end %>
