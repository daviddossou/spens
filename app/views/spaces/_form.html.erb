<%= render 'shared/form_errors', object: form.object %>

<div class="space-form__container">
  <div class="space-form__field">
    <%= render Forms::InputFieldComponent.new(
      form: form,
      field: :name,
      label: t('spaces.form.name_label'),
      required: true,
      placeholder: t('spaces.form.name_placeholder')
    ) %>
  </div>

  <div class="space-form__field">
    <%= render Forms::SelectFieldComponent.new(
      form: form,
      field: :country,
      options: CountryService.all,
      priority_options: CountryService.priority,
      searchable: true,
      label: t('spaces.form.country_label'),
      include_blank: true
    ) %>
  </div>

  <div class="space-form__field">
    <%= render Forms::SelectFieldComponent.new(
      form: form,
      field: :currency,
      options: CurrencyService.all,
      priority_options: CurrencyService.priority,
      searchable: true,
      label: t('spaces.form.currency_label'),
      include_blank: true
    ) %>
  </div>

  <div class="space-form__field">
    <%= render Forms::SelectFieldComponent.new(
      form: form,
      field: :locale,
      options: Space::LOCALES.map { |l| [{ "en" => "English", "fr" => "Français" }.fetch(l, l), l] },
      selected: form.object.locale || I18n.locale.to_s,
      label: t('spaces.form.locale_label'),
      help_text: t('spaces.form.locale_help')
    ) %>
  </div>

  <div class="space-form__field">
    <%= render Forms::InputFieldComponent.new(
      form: form,
      field: :monthly_savings_goal,
      type: :number_field,
      label: t('spaces.form.monthly_savings_goal_label'),
      help_text: t('spaces.form.monthly_savings_goal_help'),
      prepend: form.object.currency || "XOF",
      step: "0.01",
      min: "0"
    ) %>
  </div>
</div>
