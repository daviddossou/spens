<% content_for :title, t('.title') %>

<div class="page-container page-container--narrow">
  <header class="page-header">
    <p class="page-header__subtitle"><%= t('.subtitle', space_name: @space.name) %></p>
  </header>

  <div class="page-content">
    <% if @members.any? %>
      <div class="member-list">
        <% @members.each do |member| %>
          <% full_name = "#{member.first_name} #{member.last_name}".strip %>
          <div class="member-card">
            <span class="member-card__avatar" aria-hidden="true"><%= (full_name.presence || member.email).first.upcase %></span>
            <div class="member-card__info">
              <p class="member-card__name"><%= full_name.presence || member.email %></p>
              <% if full_name.present? %>
                <p class="member-card__email"><%= member.email %></p>
              <% end %>
            </div>
            <% if member.id == @space.user_id %>
              <span class="member-card__badge member-card__badge--owner"><%= t('.owner') %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @pending_invitations.any? %>
      <h3 class="member-list__section-title"><%= t('.pending_title') %></h3>
      <div class="member-list">
        <% @pending_invitations.each do |invitation| %>
          <div class="member-card member-card--pending">
            <span class="member-card__avatar member-card__avatar--pending" aria-hidden="true"><%= invitation.email.first.upcase %></span>
            <div class="member-card__info">
              <p class="member-card__name"><%= invitation.email %></p>
              <p class="member-card__email"><%= t('.invited_on', date: l(invitation.created_at.to_date, format: :short)) %></p>
            </div>
            <span class="member-card__badge member-card__badge--pending"><%= t('.pending') %></span>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%= render Ui::FabComponent.new(url: new_space_member_path(space_id: @space.id), label: t('.invite_member')) %>
