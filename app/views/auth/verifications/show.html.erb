<% content_for :title, t('auth.verifications.title') %>
<% content_for :subtitle, t('auth.verifications.subtitle', email: @email) %>

<% if turbo_native_app? %>
  <div style="margin-bottom: 1rem; padding: 0.75rem 1rem; background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 0.5rem; font-size: 0.875rem; color: #0369a1;">
    📧 Open your email app, copy the 6-digit code, and return here to paste it.
  </div>
<% end %>

<%= form_with url: auth_verification_path, method: :post, class: "space-y-6", data: { controller: "otp-input" } do |f| %>
  <div class="form-group">
    <label for="otp_code" class="form-label"><%= t('auth.verifications.code_label') %></label>
    <input type="text"
           name="otp_code"
           id="otp_code"
           class="form-input otp-input"
           inputmode="numeric"
           pattern="[0-9]*"
           maxlength="6"
           autocomplete="one-time-code"
           required
           autofocus
           data-otp-input-target="input"
           data-action="input->otp-input#handleInput"
           placeholder="000000">
  </div>

  <%= render Ui::ButtonComponent.new(
    form: f,
    text: t('auth.verifications.verify'),
    variant: :primary,
    full_width: true
  ) %>
<% end %>

<div class="mt-6 text-center space-y-3">
  <%= button_to t('auth.verifications.resend'), resend_otp_path, method: :post,
      class: "text-sm font-medium text-primary hover:text-secondary" %>

  <%= link_to t('auth.verifications.back'), new_user_session_path,
      class: "block text-sm text-gray-500 hover:text-gray-700" %>
</div>
