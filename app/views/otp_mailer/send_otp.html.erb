<h2 style="color: #333; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; margin-bottom: 16px;">
  <%= t('auth.mailer.otp.greeting', name: @user.first_name) %>
</h2>

<p style="color: #555; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 16px; line-height: 1.5;">
  <%= t('auth.mailer.otp.message') %>
</p>

<div style="background-color: #f5f5f5; padding: 24px; text-align: center; border-radius: 8px; margin: 24px 0;">
  <span style="font-size: 36px; font-weight: bold; letter-spacing: 8px; font-family: 'Courier New', monospace; color: #111;">
    <%= @otp_code %>
  </span>
</div>

<p style="color: #888; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 14px; line-height: 1.5;">
  <%= t('auth.mailer.otp.expires') %>
</p>

<p style="color: #888; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 14px; line-height: 1.5;">
  <%= t('auth.mailer.otp.ignore') %>
</p>
