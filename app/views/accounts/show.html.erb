<% content_for :title, @account.name %>

<div class="page-container page-container--narrow">
  <header class="page-header">
    <p class="page-header__subtitle"><%= t('.subtitle') %></p>
  </header>

  <div class="page-content"
       data-controller="infinite-scroll"
       data-infinite-scroll-url-value="<%= account_path(id: @account.id) %>"
       data-infinite-scroll-page-value="<%= @has_more ? @page + 1 : 0 %>">
    <div class="account-detail">
      <span class="account-detail__balance-label"><%= t('.balance') %></span>
      <span class="account-detail__balance-value <%= 'account-detail__balance-value--negative' if @account.balance.negative? %>"><%= smart_format_money(@account.balance, current_space.currency) %></span>

      <% if @account.saving_goal.to_f > 0 %>
        <div class="account-detail__goal">
          <span class="account-detail__goal-label"><%= t('.saving_goal') %></span>
          <span class="account-detail__goal-value"><%= smart_format_money(@account.saving_goal, current_space.currency) %></span>
        </div>
      <% end %>
    </div>

    <div class="commitment-actions">
      <div class="action-buttons">
        <%= render Ui::ButtonComponent.new(
          text: t('.add_transaction'),
          url: new_transaction_path(kind: 'transfer', account_id: @account.id),
          variant: :primary,
          size: :lg,
          full_width: true,
          data: { turbo_frame: "modal" }
        ) %>

        <%= render Ui::ButtonComponent.new(
          text: t('.edit_account'),
          url: edit_account_path(id: @account.id),
          variant: :"outline-secondary",
          size: :lg,
          full_width: true,
          data: { turbo_frame: "modal" }
        ) %>

        <% unless @account.transactions.exists? %>
          <%= render Ui::ButtonComponent.new(
            text: t('.delete_account'),
            url: account_path(id: @account.id),
            variant: :danger,
            size: :lg,
            full_width: true,
            method: :delete,
            data: { "turbo-confirm" => t('.delete_confirmation') }
          ) %>
        <% end %>
      </div>
    </div>

    <div class="commitment-transactions">
      <h2 class="commitment-section-title"><%= t('.recent_transactions') %></h2>
      <% if @transactions.any? %>
        <div id="transactions-container" class="transactions-timeline">
          <%= render partial: "shared/transactions_list", locals: { grouped_transactions: @grouped_transactions } %>
        </div>

        <div id="loading-spinner"
             data-infinite-scroll-target="spinner"
             class="dashboard__spinner hidden">
          <div class="dashboard__spinner-icon"></div>
          <p class="dashboard__spinner-text"><%= t('home.show.loading') %></p>
        </div>

        <% if @has_more %>
          <div id="infinite-scroll-trigger"
               data-infinite-scroll-target="trigger"
               class="dashboard__load-trigger"></div>
        <% end %>
      <% else %>
        <div class="empty-state">
          <p><%= t('.no_transactions') %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%= render Ui::FabComponent.new(url: new_transaction_path, label: t('.add_transaction')) %>
