<% content_for :title, t('.title') %>

<%= turbo_frame_tag "modal" do %>
  <div class="page-container page-container--narrow">
    <header class="page-header">
      <p class="page-header__subtitle">
        <%= t('.subtitle', type: @budget_entry.display_name, month: l(@budget_entry.month, format: :month_year)) %>
      </p>
    </header>

    <div class="page-content">
      <%= form_with model: @budget_entry, url: budget_entry_path(id: @budget_entry.id), method: :patch, class: "budget-item-form" do |f| %>
        <%= render "shared/form_errors", object: @budget_entry %>

        <div class="budget-item-form__amount">
          <%= render Forms::InputFieldComponent.new(
            form: f,
            field: :planned_amount,
            type: :number_field,
            label: t('.planned_amount_label'),
            required: true,
            value: (@budget_entry.planned_amount % 1 == 0 ? @budget_entry.planned_amount.to_i : @budget_entry.planned_amount.to_f),
            prepend: get_currency_symbol(current_space.currency),
            step: "0.01",
            min: "0.01"
          ) %>
          <p class="form-help-text"><%= t('.override_help') %></p>
        </div>

        <div class="budget-item-form__actions">
          <%= render Ui::ButtonComponent.new(
            text: t('.save'),
            type: :submit,
            variant: :primary,
            size: :lg,
            full_width: true
          ) %>

          <% if @budget_entry.budget_item %>
            <%= render Ui::ButtonComponent.new(
              text: t('.edit_rule'),
              url: edit_budget_item_path(id: @budget_entry.budget_item_id, month: @budget_entry.month.strftime("%Y-%m")),
              variant: :"outline-secondary",
              size: :lg,
              full_width: true,
              data: { turbo_frame: "modal" }
            ) %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
