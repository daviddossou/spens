<% content_for :page_title, t('.dashboard_title') %>

<div class="page-container page-container--narrow">
  <div class="page-content"
       data-controller="infinite-scroll"
       data-infinite-scroll-url-value="<%= dashboard_path %>"
       data-infinite-scroll-page-value="<%= @has_more ? @page + 1 : 0 %>">

    <!-- Hero: the one glanceable number -->
    <%= render Ui::StatCardComponent.new(
      label: t('.stats.total_balance'),
      value: @total_balance,
      currency: @currency,
      variant: :hero,
      icon: tag.svg(fill: "none", stroke: "currentColor", viewBox: "0 0 24 24") do
        tag.path(stroke_linecap: "round", stroke_linejoin: "round", "stroke-width": "1.8",
                 d: "M3 7a2 2 0 012-2h12a2 2 0 012 2v1h1a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2V7zm15 5h-3a1.5 1.5 0 100 3h3")
      end
    ) %>

    <!-- Secondary stats -->
    <div class="stat-cards">
      <%= render Ui::StatCardComponent.new(
        label: t('.stats.saved_this_month'),
        value: @saved_this_month,
        currency: @currency,
        variant: :compact,
        trend: @saved_this_month.positive? ? :positive : (@saved_this_month.negative? ? :negative : nil)
      ) %>
      <%= render Ui::StatCardComponent.new(
        label: t('.stats.owed_to_me'),
        value: @owed_to_me,
        currency: @currency,
        variant: :compact,
        trend: @owed_to_me.positive? ? :positive : nil
      ) %>
      <%= render Ui::StatCardComponent.new(
        label: t('.stats.i_owe'),
        value: @i_owe,
        currency: @currency,
        variant: :compact,
        trend: @i_owe.positive? ? :negative : nil
      ) %>
    </div>

    <!-- Transactions List -->
    <div id="transactions-container" class="transactions-timeline">
      <%= render partial: "shared/transactions_list", locals: { grouped_transactions: @grouped_transactions } %>
    </div>

    <!-- Loading Spinner -->
    <div id="loading-spinner"
         data-infinite-scroll-target="spinner"
         class="dashboard__spinner hidden">
      <div class="dashboard__spinner-icon"></div>
      <p class="dashboard__spinner-text"><%= t('.loading') %></p>
    </div>

    <!-- Load More Trigger (Invisible) -->
    <% if @has_more %>
      <div id="infinite-scroll-trigger"
           data-infinite-scroll-target="trigger"
           class="dashboard__load-trigger"></div>
    <% end %>

    <!-- Empty State -->
    <% if @transactions.empty? && @page == 1 %>
      <%= render partial: "empty_state" %>
    <% end %>
  </div>
</div>

<%= render Ui::FabComponent.new(url: new_quick_entry_path, label: t('.quick_add'), icon: :bolt, secondary: true) %>
<%= render Ui::FabComponent.new(url: new_transaction_path, label: t('.add_transaction')) %>
