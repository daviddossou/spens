<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Spens" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="Spens">
    <meta name="description" content="Track your money simply">
    <meta property="og:title" content="Spens">
    <meta property="og:description" content="Track your money simply">
    <meta property="og:image" content="/icon-512.png">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="Spens">
    <meta name="twitter:description" content="Track your money simply">
    <meta name="twitter:image" content="/icon-512.png">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#3F51B5">

    <%# Google Fonts: Geist Sans + Plus Jakarta Sans (fallback) %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <%# TomSelect base CSS (vendored) %>
    <%= stylesheet_link_tag "tom-select.bootstrap5", "data-turbo-track": "reload" %>

    <%= javascript_importmap_tags %>
  </head>

  <body style="background-color: var(--color-off-white);">
    <% if user_signed_in? %>
      <%= render Navigation::HeaderComponent.new(
        page_title: content_for(:page_title).presence || content_for(:title).presence || "Spens",
        current_user: current_user,
        current_space: current_space,
        params: params
      ) %>
    <% end %>

    <main class="main-container<%= ' main-container--with-shell' if user_signed_in? %>">
      <!-- Flash messages -->
      <%= render Ui::FlashMessageComponent.new(flash) %>

      <%= yield %>
    </main>

    <% if user_signed_in? %>
      <%= render Navigation::BottomNavComponent.new(current_path: request.path) %>

      <!-- Bottom Sheet Modal -->
      <div class="bottom-sheet" data-controller="bottom-sheet">
        <div class="bottom-sheet__backdrop" data-action="click->bottom-sheet#close" data-bottom-sheet-target="backdrop"></div>
        <div class="bottom-sheet__panel" data-bottom-sheet-target="panel">
          <div class="bottom-sheet__handle-bar"><span class="bottom-sheet__handle"></span></div>
          <button class="bottom-sheet__close" data-action="click->bottom-sheet#close" aria-label="Close">&times;</button>
          <div class="bottom-sheet__body">
            <%= turbo_frame_tag "modal",
              data: {
                bottom_sheet_target: "frame",
                action: "turbo:frame-load->bottom-sheet#frameLoaded turbo:frame-missing->bottom-sheet#frameMissing"
              } %>
          </div>
        </div>
      </div>
    <% end %>
  </body>
</html>
