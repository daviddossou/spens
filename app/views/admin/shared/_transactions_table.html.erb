<%# Locals: transactions, show_space (optional) %>
<% if transactions.any? %>
  <table class="admin-table">
    <thead>
      <tr>
        <th><%= t("admin.cols.date") %></th>
        <th><%= t("admin.cols.type") %></th>
        <th><%= t("admin.cols.amount") %></th>
        <th><%= t("admin.cols.account") %></th>
        <% if local_assigns[:show_space] %><th><%= t("admin.cols.space") %></th><% end %>
      </tr>
    </thead>
    <tbody>
      <% transactions.each do |txn| %>
        <tr>
          <td><%= txn.transaction_date.strftime("%Y-%m-%d") %></td>
          <td><%= txn.transaction_type&.name || "—" %></td>
          <td class="admin-amount"><%= format_money(txn.amount, txn.space.currency) %></td>
          <td><%= txn.account&.name || "—" %></td>
          <% if local_assigns[:show_space] %>
            <td><%= link_to txn.space.name, admin_space_path(id: txn.space_id) %></td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="admin-empty"><%= t("admin.transactions.empty") %></p>
<% end %>
