<%# Locals: attempts, show_user (optional) %>
<% if attempts.any? %>
  <div class="admin-table-wrap"><table class="admin-table">
    <thead>
      <tr>
        <th scope="col"><%= t("admin.cols.when") %></th>
        <% if local_assigns[:show_user] %><th scope="col"><%= t("admin.cols.user") %></th><% end %>
        <th scope="col"><%= t("admin.cols.utterance") %></th>
        <th scope="col"><%= t("admin.cols.source") %></th>
        <th scope="col"><%= t("admin.cols.outcome") %></th>
      </tr>
    </thead>
    <tbody>
      <% attempts.each do |attempt| %>
        <tr>
          <td><%= admin_time(attempt.created_at) %></td>
          <% if local_assigns[:show_user] %>
            <td><%= link_to attempt.user.email, admin_user_path(id: attempt.user_id) %></td>
          <% end %>
          <td>
            <code><%= truncate(attempt.text, length: 50) %></code>
            <span class="admin-row__type"><%= attempt.locale %></span>
          </td>
          <td><%= admin_badge(attempt.source) %></td>
          <td><%= admin_outcome_badge(attempt.outcome) %></td>
        </tr>
      <% end %>
    </tbody>
  </table></div>
<% else %>
  <p class="admin-empty"><%= t("admin.attempts.empty") %></p>
<% end %>
