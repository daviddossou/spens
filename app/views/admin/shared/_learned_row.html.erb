<%# Locals: row (LearnedAlias|LearnedKeyword), samples_by_id (optional Hash) %>
<% samples = local_assigns[:samples_by_id]&.dig(row.id) %>
<tr id="<%= dom_id(row) %>" class="admin-row">
  <td>
    <code><%= row.phrase %></code>
    <% if samples.present? %>
      <ul class="admin-samples">
        <% samples.each do |utterance| %>
          <li>"<%= truncate(utterance, length: 60) %>"</li>
        <% end %>
      </ul>
    <% end %>
  </td>
  <td><%= learned_target(row) %> <span class="admin-row__type"><%= learned_type_label(row) %></span></td>
  <td><%= admin_badge(row.source) %></td>
  <td><%= row.confirmations %></td>
  <td><%= admin_state_badge(row.state) %></td>
  <td class="admin-table__actions">
    <% unless row.active? %>
      <%# Approve with optional inline edits: fix the phrase / retarget before it goes live. %>
      <%= form_with url: approve_learned_path(row), method: :patch, class: "admin-teach" do |f| %>
        <%= f.text_field :phrase, value: row.phrase, class: "admin-input admin-input--sm" %>
        <% if row.is_a?(LearnedKeyword) %>
          <%= f.select :kind,
                options_for_select(LearnedKeyword::KINDS.map { |k| [ t("admin.kinds.#{k}"), k ] }, row.kind),
                {}, class: "admin-input admin-input--sm" %>
        <% else %>
          <%= f.select :taxonomy_key,
                grouped_options_for_select(taxonomy_grouped_options, row.taxonomy_key),
                {}, class: "admin-input admin-input--sm" %>
        <% end %>
        <%= f.submit t("admin.review.approve"), class: "admin-btn admin-btn--success admin-btn--sm" %>
      <% end %>
    <% end %>
    <% unless row.rejected? %>
      <%= button_to t("admin.review.reject"), reject_learned_path(row), method: :patch,
            class: "admin-btn admin-btn--danger admin-btn--sm" %>
    <% end %>
  </td>
</tr>
