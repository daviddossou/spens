<% content_for(:title, t("admin.audit.title")) %>

<div class="admin-page">
  <header class="admin-page__header">
    <h1 class="admin-page__title"><%= t("admin.audit.title") %></h1>
    <p class="admin-page__subtitle"><%= t("admin.audit.subtitle") %></p>
  </header>

  <% if @logs.any? %>
    <div class="admin-table-wrap"><table class="admin-table">
      <thead>
        <tr>
          <th scope="col"><%= t("admin.cols.when") %></th>
          <th scope="col"><%= t("admin.cols.admin") %></th>
          <th scope="col"><%= t("admin.cols.action") %></th>
          <th scope="col"><%= t("admin.cols.target") %></th>
        </tr>
      </thead>
      <tbody>
        <% @logs.each do |log| %>
          <tr>
            <td><%= admin_time(log.created_at) %></td>
            <td><%= log.admin_user&.email %></td>
            <td><%= admin_badge(t("admin.actions.#{log.action}", default: log.action)) %></td>
            <td><%= admin_audit_target(log) %></td>
          </tr>
        <% end %>
      </tbody>
    </table></div>
  <% else %>
    <p class="admin-empty"><%= t("admin.audit.empty") %></p>
  <% end %>

  <%= render "admin/shared/pagination" %>
</div>
