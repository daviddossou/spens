<%= form_with model: @form,
              url: onboarding_profile_setups_path,
              method: :patch,
              class: "onboarding-form",
              data: { controller: "onboarding--profile-prefill" } do |f| %>
  <%= render 'shared/form_errors', object: @form %>

  <div class="form-grid">
    <%= render Onboarding::ProfileSetups::SelectFieldComponent.new(
      form: f,
      field: :country,
      required: true,
      include_blank: true
    ) %>

    <%= render Onboarding::ProfileSetups::SelectFieldComponent.new(
      form: f,
      field: :currency,
      required: true,
      include_blank: true
    ) %>

    <%= render Onboarding::ProfileSetups::SelectFieldComponent.new(
      form: f,
      field: :income_frequency,
      include_blank: true
    ) %>

    <%= render Onboarding::ProfileSetups::SelectFieldComponent.new(
      form: f,
      field: :main_income_source,
      include_blank: true
    ) %>

    <%= render Forms::InputFieldComponent.new(
      form: f,
      field: :monthly_savings_goal,
      type: :number_field,
      label: t('.monthly_savings_goal_label'),
      help_text: t('.monthly_savings_goal_help'),
      prepend: current_space.currency || "XOF",
      step: "0.01",
      min: "0"
    ) %>
  </div>

  <div class="form-actions">
    <%= render Ui::ButtonComponent.new(
          text: t('.back'),
          url: onboarding_financial_goals_path,
          variant: :'outline-secondary',
          size: :lg
        ) %>
    <%= render Ui::ButtonComponent.new(
          text: t('.continue'),
          type: :submit,
          variant: :primary,
          size: :lg,
          form: f,
        ) %>
  </div>
<% end %>
