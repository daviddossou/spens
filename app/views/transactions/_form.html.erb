<%# Shared form for create and edit. Locals form_url / form_method default to
    the create endpoint; edit passes the transaction path + :patch. %>
<%= form_with model: @form,
      url: local_assigns.fetch(:form_url, transactions_path),
      method: local_assigns.fetch(:form_method, :post),
      class: "transaction-form",
      data: {
        controller: "transaction-form debt-fields kind-switch",
        action: "tom-select:change->transaction-form#keepTypedText",
        debt_fields_intent_labels_value: debt_intent_label_map.to_json,
        debt_fields_debts_by_name_value: @form.debts_by_name.to_json,
        debt_fields_contact_name_value: @form.contact_name,
        debt_fields_locked_value: @form.debt_id.present?
      } do |f| %>
    <%= render "shared/form_errors", object: @form %>

    <!-- Hidden field to store the selected kind -->
    <%= f.hidden_field :kind, data: { debt_fields_target: "kindInput" } %>
    <%= f.hidden_field :quick_entry_attempt_id %>

    <!-- Kind Selector (hidden when opened from a specific debt — the kind is fixed) -->
    <% unless @form.debt_id.present? %>
      <div class="transaction-form__kind">
        <div class="kind-selector kind-selector--quad" role="radiogroup" aria-label="<%= t('transactions.form.kind_label', default: 'Type') %>">
          <% transaction_top_level_options(@form).each do |opt| %>
            <%= link_to transaction_kind_switch_path(@form, opt[:kind]),
                        data: { turbo_frame: "transaction_form", action: "kind-switch#switch" },
                        role: "radio",
                        "aria-checked": opt[:selected].to_s,
                        class: "kind-option kind-option--#{opt[:value]}#{' kind-option--selected' if opt[:selected]}" do %>
              <span class="kind-option__icon kind-option__icon--<%= opt[:value] %>" aria-hidden="true">
                <%= transaction_icon_svg(opt[:value]) %>
              </span>
              <span class="kind-option__label"><%= opt[:label] %></span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Amount Field (Required) -->
    <div class="transaction-form__amount">
      <%= render Forms::InputFieldComponent.new(
        form: f,
        field: :amount,
        type: :number_field,
        label: t('transactions.form.amount_label'),
        required: true,
        prepend: get_currency_symbol(current_space.currency),
        step: "0.01",
        min: "0.01",
        placeholder: t('transactions.form.amount_placeholder'),
        autofocus: true
      ) %>
    </div>

    <!-- Transfer Mode: From and To Accounts -->
    <% if @form.kind == 'transfer' %>
      <div class="transaction-form__transfer-accounts">
        <div class="transaction-form__from-account">
          <%= render Forms::InputFieldComponent.new(
            form: f,
            field: :from_account_name,
            label: t('transactions.form.from_account_label'),
            required: true,
            autocomplete: true,
            autocomplete_options: @form.account_suggestions,
            default_autocomplete_options: @form.default_account_suggestions,
            allow_create: true,
            placeholder: t('transactions.form.from_account_placeholder'),
            field_data: { tom_select_currency_value: get_currency_symbol(current_space.currency) }
          ) %>
        </div>

        <div class="transaction-form__to-account">
          <%= render Forms::InputFieldComponent.new(
            form: f,
            field: :to_account_name,
            label: t('transactions.form.to_account_label'),
            required: true,
            autocomplete: true,
            autocomplete_options: @form.account_suggestions,
            default_autocomplete_options: @form.default_account_suggestions,
            allow_create: true,
            placeholder: t('transactions.form.to_account_placeholder'),
            field_data: { tom_select_currency_value: get_currency_symbol(current_space.currency) }
          ) %>
        </div>
      </div>
    <% elsif @form.debt_transaction? %>
      <!-- Debt Mode: person-first. Pick who, infer/choose direction, pick intent. -->
      <%= f.hidden_field :debt_id %>
      <%= f.hidden_field :direction, data: { debt_fields_target: "directionInput" } %>

      <!-- Who? (hidden when opened from a specific debt — the person is fixed) -->
      <% unless @form.debt_id.present? %>
        <div class="transaction-form__contact">
          <%= render Forms::InputFieldComponent.new(
            form: f,
            field: :contact_name,
            label: t('transactions.form.contact_name_label'),
            autocomplete: true,
            autocomplete_options: @form.debt_person_suggestions,
            allow_create: true,
            placeholder: t('transactions.form.contact_name_placeholder'),
            field_data: { action: "tom-select:change->debt-fields#onPersonChange change->debt-fields#onPersonChange" }
          ) %>
        </div>
      <% end %>

      <!-- Direction picker (always shown once a person is set, preselected when inferable,
           so a wrong quick-entry/AI guess stays correctable) -->
      <div class="transaction-form__debt-direction kind-selector hidden"
           data-debt-fields-target="directionPicker" role="radiogroup"
           aria-label="<%= t('transactions.form.direction_label') %>">
        <% [["lent", t('transactions.form.direction_lent')], ["borrowed", t('transactions.form.direction_borrowed')]].each do |dir, label| %>
          <button type="button" class="kind-option kind-option--choice"
                  data-debt-fields-target="directionOption"
                  data-direction="<%= dir %>"
                  data-action="click->debt-fields#selectDirection">
            <span class="kind-option__label"><%= label %></span>
          </button>
        <% end %>
      </div>

      <!-- Intent cards (the 2 actions for the resolved direction) -->
      <% intent_direction = @form.direction.presence || "lent" %>
      <div class="transaction-form__debt-intents kind-selector<%= ' hidden' unless @form.direction.present? || @form.debt_id.present? %>"
           data-debt-fields-target="intents" role="radiogroup"
           aria-label="<%= t('transactions.form.kind_label', default: 'Type') %>">
        <% debt_direction_intent_options(intent_direction).each do |io| %>
          <button type="button"
                  class="kind-option kind-option--<%= io[:kind] %> <%= 'kind-option--selected' if @form.kind == io[:kind] %>"
                  data-debt-fields-target="intentOption"
                  data-kind="<%= io[:kind] %>"
                  data-action="click->debt-fields#selectIntent">
            <span class="kind-option__label" data-label><%= io[:label] %></span>
          </button>
        <% end %>
      </div>

      <!-- Account (optional) -->
      <div class="transaction-form__account">
        <%= render Forms::InputFieldComponent.new(
          form: f,
          field: :account_name,
          label: t('transactions.form.account_label'),
          autocomplete: true,
          autocomplete_options: @form.account_suggestions,
          default_autocomplete_options: @form.default_account_suggestions,
          allow_create: true,
          placeholder: t('transactions.form.account_placeholder'),
          field_data: { tom_select_currency_value: get_currency_symbol(current_space.currency) }
        ) %>
      </div>
    <% else %>
      <!-- Regular Mode: Single Account and Transaction Type -->
      <div class="transaction-form__account">
        <%= render Forms::InputFieldComponent.new(
          form: f,
          field: :account_name,
          label: t('transactions.form.account_label'),
          autocomplete: true,
          autocomplete_options: @form.account_suggestions,
          default_autocomplete_options: @form.default_account_suggestions,
          allow_create: true,
          placeholder: t('transactions.form.account_placeholder'),
          field_data: { tom_select_currency_value: get_currency_symbol(current_space.currency) }
        ) %>
      </div>

      <div class="transaction-form__transaction-type">
        <%= render Forms::InputFieldComponent.new(
          form: f,
          field: :transaction_type_name,
          label: t('transactions.form.transaction_type_label'),
          required: true,
          autocomplete: true,
          autocomplete_options: @form.transaction_type_options,
          default_autocomplete_options: @form.default_transaction_type_options,
          allow_create: true,
          placeholder: t('transactions.form.transaction_type_placeholder')
        ) %>
      </div>
    <% end %>

    <!-- More Details Toggle -->
    <div class="transaction-form__toggle">
      <button
        type="button"
        class="link-button"
        data-action="click->transaction-form#toggleDetails"
        data-transaction-form-target="toggleButton"
        data-show-text="<%= t('transactions.form.show_more_details') %>"
        data-hide-text="<%= t('transactions.form.hide_more_details') %>">
        <%= t('transactions.form.show_more_details') %>
      </button>
    </div>

    <!-- Optional Fields (expanded when an existing fee needs editing) -->
    <div class="transaction-form__optional-fields<%= ' hidden' unless @form.fee_amount.present? %>"
         data-transaction-form-target="optionalFields"
         data-expanded="<%= @form.fee_amount.present? %>">
      <div class="transaction-form__description">
        <%= render Forms::InputFieldComponent.new(
          form: f,
          field: :description,
          label: t('transactions.form.description_label'),
          help_text: t('transactions.form.description_help'),
          placeholder: t('transactions.form.description_placeholder'),
          required: false
        ) %>
      </div>

      <% if @form.fee_applicable? || @form.debt_transaction? %>
        <div class="transaction-form__fee<%= ' hidden' unless @form.fee_applicable? %>" data-debt-fields-target="feeField">
          <%= render Forms::InputFieldComponent.new(
            form: f,
            field: :fee_amount,
            type: :number_field,
            label: t('transactions.form.fee_amount_label'),
            help_text: t('transactions.form.fee_help'),
            required: false,
            prepend: get_currency_symbol(current_space.currency),
            step: "0.01",
            min: "0",
            placeholder: t('transactions.form.fee_amount_placeholder')
          ) %>
        </div>
      <% end %>

      <div class="transaction-form__date">
        <%= render Forms::InputFieldComponent.new(
          form: f,
          field: :transaction_date,
          type: :date_field,
          label: t('transactions.form.date_label'),
          required: false
        ) %>
      </div>

      <div class="transaction-form__note">
        <%= render Forms::InputFieldComponent.new(
          form: f,
          field: :note,
          type: :text_area,
          label: t('transactions.form.note_label'),
          help_text: t('transactions.form.note_help'),
          rows: 3,
          placeholder: t('transactions.form.note_placeholder')
        ) %>
      </div>
    </div>

    <!-- Submit Button -->
    <div class="transaction-form__actions">
      <%= render Ui::ButtonComponent.new(
        text: @form.editing? ? t('transactions.edit.update_transaction') : t('transactions.form.save_transaction'),
        type: :submit,
        variant: :primary,
        size: :lg,
        full_width: true
      ) %>
    </div>
  <% end %>
