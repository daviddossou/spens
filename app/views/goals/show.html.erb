<% content_for :title, @account.name %>

<div class="page-container page-container--narrow">
  <header class="page-header">
    <p class="page-header__subtitle"><%= t('.subtitle') %></p>
  </header>

  <div class="page-content">
    <%= render Ui::CommitmentCardComponent.new(
      title: @account.name,
      current_value: @account.balance,
      target_value: @account.saving_goal,
      currency: current_space.currency,
      accent: "primary",
      progress_label: t('goals.index.saved_label'),
      complete_label: t('goals.index.reached_label'),
      remaining_label: t('goals.index.to_go_label')
    ) %>

    <div class="commitment-actions">
      <div class="action-buttons">
        <%= render Ui::ButtonComponent.new(
          text: t('.add_transaction'),
          url: new_transaction_path(kind: 'transfer', account_id: @account.id),
          variant: :primary,
          size: :lg,
          full_width: true,
          data: { turbo_frame: "modal" }
        ) %>

        <%= render Ui::ButtonComponent.new(
          text: t('.edit_goal'),
          url: edit_goal_path(id: @account.id),
          variant: :"outline-secondary",
          size: :lg,
          full_width: true,
          data: { turbo_frame: "modal" }
        ) %>
      </div>
    </div>

    <div class="commitment-transactions">
      <h2 class="commitment-section-title"><%= t('.recent_transactions') %></h2>
      <% if @latest_transactions.any? %>
        <div class="transactions-list">
          <%= render TransactionItemComponent.with_collection(@latest_transactions, transaction: :itself) %>
        </div>
      <% else %>
        <div class="empty-state">
          <p><%= t('.no_transactions') %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%= render Ui::FabComponent.new(url: new_goal_path, label: t('.add_goal')) %>
