<header class="page-header">
  <p class="page-header__subtitle"><%= t('.subtitle') %></p>
</header>

<div class="page-content">
  <%= form_with url: quick_entry_path, method: :post, class: "quick-entry" do |f| %>
    <%= f.text_field :text,
          autofocus: true,
          autocomplete: "off",
          enterkeyhint: "send",
          class: "form-input quick-entry__input",
          placeholder: t('.placeholder'),
          aria: { label: t('.subtitle') } %>

    <p class="quick-entry__examples"><%= t('.examples') %></p>

    <div class="transaction-form__actions">
      <%= render Ui::ButtonComponent.new(
        text: t('.submit'),
        type: :submit,
        variant: :primary,
        size: :lg,
        full_width: true
      ) %>
    </div>
  <% end %>
</div>
