#!/bin/bash

# Docker management script for Spens

set -euo pipefail

# Compose v2 is a docker plugin ("docker compose"); fall back to the legacy v1 binary.
if docker compose version >/dev/null 2>&1; then
  compose() { docker compose "$@"; }
else
  compose() { docker-compose "$@"; }
fi

web() { compose exec web "$@"; }
# Test runs must not inherit the container's dev RAILS_ENV/DATABASE_URL (docker-compose.yml
# exports spens_development) — point them explicitly at the test database.
webtest() {
  compose exec -e RAILS_ENV=test -e DATABASE_URL=postgresql://postgres:password@db:5432/spens_test web "$@"
}

case ${1:-} in
  "up")
    echo "🚀 Starting all services..."
    compose up
    ;;
  "down")
    echo "🛑 Stopping all services..."
    compose down
    ;;
  "restart")
    if [ -z "${2:-}" ]; then
      echo "🔄 Restarting all services..."
      compose down
      compose up -d
    else
      echo "🔄 Restarting $2 service..."
      compose restart "$2"
    fi
    ;;
  "logs")
    service=${2:-web}
    echo "📄 Following logs for $service..."
    compose logs -f "$service"
    ;;
  "console")
    echo "🎯 Opening Rails console..."
    web bin/rails console
    ;;
  "shell")
    echo "🐚 Opening shell in web container..."
    web bash
    ;;
  "test")
    if [ -z "${2:-}" ]; then
      echo "🧪 Running all tests..."
      webtest bundle exec rspec
    else
      echo "🧪 Running specific test: ${*:2}"
      webtest bundle exec rspec "${@:2}"
    fi
    ;;
  "bundle")
    if [ -z "${2:-}" ]; then
      echo "💎 Running bundle install..."
      web bundle install
    else
      echo "💎 Running bundle ${*:2}..."
      web bundle "${@:2}"
    fi
    ;;
  "rails")
    if [ -z "${2:-}" ]; then
      echo "🚂 Opening Rails console..."
      web bin/rails console
    else
      echo "🚂 Running Rails command: ${*:2}"
      web bin/rails "${@:2}"
    fi
    ;;
  "migrate")
    echo "🗄️  Running migrations..."
    web bin/rails db:migrate
    ;;
  "rollback")
    if [ -z "${2:-}" ]; then
      echo "🔁 Rolling back the latest migration file..."
      web bin/rails db:rollback
    else
      echo "🔁 Rolling back $2 migration(s)..."
      web bin/rails db:rollback STEP="$2"
    fi
    ;;
  "seed")
    echo "🌱 Seeding database..."
    web bin/rails db:seed
    ;;
  "reset")
    echo "💥 Resetting database..."
    web bin/rails db:reset
    ;;
  "build")
    echo "🔨 Building containers..."
    compose build
    ;;
  "test-watch")
    echo "👀 Running tests in watch mode..."
    webtest bundle exec rspec --format documentation --color --fail-fast
    ;;
  "test-debug")
    echo "🐛 Running tests with debugging enabled..."
    webtest bundle exec rspec --format documentation --color --backtrace
    ;;
  "clean")
    echo "🧹 Cleaning up containers and volumes..."
    compose down -v
    docker system prune -f
    ;;
  "rubocop")
    echo "🔍 Running RuboCop on: ${2:-all files}"
    web bundle exec rubocop "${@:2}"
    ;;
  "rubocop-fix")
    echo "🔧 Auto-correcting safe RuboCop offenses on: ${2:-all files}"
    web bundle exec rubocop -a "${@:2}"
    ;;
  "rubocop-fix-all")
    echo "⚠️  Auto-correcting ALL RuboCop offenses (including unsafe) on: ${2:-all files}"
    web bundle exec rubocop -A "${@:2}"
    ;;
  "tailwind-build")
    echo "🎨 Building Tailwind CSS (rails tailwindcss:build)..."
    web bin/rails tailwindcss:build
    ;;
  "rake")
    if [ -z "${2:-}" ]; then
      echo "📋 Please specify a rake task"
      echo "Example: ./bin/docker-manage rake db:migrate"
    else
      echo "📋 Running rake task: ${*:2}"
      web bundle exec rake "${@:2}"
    fi
    ;;
  "status")
    echo "📊 Container Status:"
    compose ps
    ;;
  *)
    echo "🐳 Spens Docker Management"
    echo ""
    echo "Usage: ./bin/docker-manage [command]"
    echo ""
    echo "Commands:"
    echo "  up           Start all services"
    echo "  down         Stop all services"
    echo "  restart      Restart all services (or specify service: web, sidekiq, db, redis)"
    echo "  logs         Follow logs (specify service: web, sidekiq, db, redis)"
    echo "  console      Open Rails console"
    echo "  shell        Open bash shell in web container"
    echo "  bundle       Run bundle commands (install by default, or specify: update, etc.)"
    echo "  rails        Run Rails commands (console by default, or generators, etc.)"
    echo "  test         Run RSpec tests (optionally specify file/pattern)"
    echo "  test-watch   Run tests with detailed output and fail-fast"
    echo "  test-debug   Run tests with debugging and full backtrace"
    echo "  migrate      Run database migrations"
    echo "  rollback     Roll back migrations (optionally specify step count)"
    echo "  seed         Seed the database"
    echo "  reset        Reset database (drop, create, migrate, seed)"
    echo "  build        Build Docker containers"
    echo "  clean        Clean up containers and volumes"
    echo ""
    echo "Code Quality Commands:"
    echo "  rubocop         Run RuboCop linter (optionally specify file/directory)"
    echo "  rubocop-fix     Auto-fix safe RuboCop issues (optionally specify file/directory)"
    echo "  rubocop-fix-all Auto-fix ALL issues including unsafe (optionally specify file/directory)"
    echo "  tailwind-build  Run Tailwind CSS build (bin/rails tailwindcss:build)"
    echo ""
    echo "Other Commands:"
    echo "  rake         Run rake tasks (specify task: db:migrate, quick_entry:mine, etc.)"
    echo "  status       Show status of all containers"
    echo ""
    echo "Examples:"
    echo "  ./bin/docker-manage up"
    echo "  ./bin/docker-manage restart web                       # Restart only web service"
    echo "  ./bin/docker-manage logs sidekiq"
    echo "  ./bin/docker-manage console"
    echo "  ./bin/docker-manage rails generate model User         # Generate a model"
    echo "  ./bin/docker-manage test spec/models/user_spec.rb:25  # Run specific line"
    echo "  ./bin/docker-manage rake \"admin:grant[user@mail.com]\" # Quote bracketed rake args (zsh)"
    echo "  ./bin/docker-manage rake -T                           # List all rake tasks"
    ;;
esac
